# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/mundial26?sslmode=require

# ─── Better Auth ──────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-secret
BETTER_AUTH_URL=https://your-api.onrender.com
BACKEND_URL=https://your-api.onrender.com
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# ─── Football APIs ────────────────────────────────────────────
# api-football.com via RapidAPI (live scores)
API_FOOTBALL_KEY=your-rapidapi-key-here
AFL_LEAGUE_ID=1
AFL_SEASON=2026

# football-data.org (static data: standings, squads)
FOOTBALL_DATA_KEY=your-football-data-org-key

# ─── Upstash Redis ────────────────────────────────────────────
UPSTASH_REDIS_URL=rediss://default:xxx@xxx.upstash.io:6379

# ─── Cloudflare R2 ────────────────────────────────────────────
CF_ACCOUNT_ID=your-cf-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=mundial26-photos

# ─── App ──────────────────────────────────────────────────────
FRONTEND_URL=https://appmundial26.vercel.app
PORT=3001
NODE_ENV=production
